# ZhiXu Environment Variables

# Database
DATABASE_URL=postgresql://zhixu:zhixu@localhost:5432/zhixu

# Store type: memory (default) or prisma
STORE_TYPE=memory

# LLM Configuration (阿里云百炼 OpenAI 兼容接口)
# Get API Key: https://help.aliyun.com/zh/model-studio/get-api-key
LLM_API_KEY=
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen3.6-plus
LLM_ENABLE_THINKING=false

# SenseNova Configuration (商汤 SenseNova - 免费)
# Get API Key: https://platform.sensenova.cn/token-plan
# Models:
#   sensenova-6.7-flash-lite  - Agent 模型 (免费, 256K context, tool calling)
#   sensenova-u1-fast         - 文生图模型 (免费, 2K resolution)
#   deepseek-v4-flash         - DeepSeek V4 (免费, 256K context, 思考模式)
SN_API_KEY=
SN_BASE_URL=https://token.sensenova.cn/v1
SN_CHAT_MODEL=sensenova-6.7-flash-lite
SN_IMAGE_MODEL=sensenova-u1-fast

# Web
WEB_ORIGIN=http://localhost:3000
