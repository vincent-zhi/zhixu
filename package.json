{
  "name": "zhixu-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "build": "pnpm --filter @zhixu/core --filter @zhixu/agent-core --filter @zhixu/agent-harness --filter @zhixu/agent-os --filter @zhixu/config --filter @zhixu/skill-runtime --filter @zhixu/document-intelligence --filter @zhixu/db build && pnpm --filter @zhixu/server --filter @zhixu/web --filter @zhixu/desktop build",
    "dev": "pnpm --parallel dev",
    "test": "pnpm --filter @zhixu/core --filter @zhixu/agent-core --filter @zhixu/agent-harness --filter @zhixu/agent-os --filter @zhixu/config --filter @zhixu/skill-runtime --filter @zhixu/document-intelligence --filter @zhixu/db build && pnpm -r test",
    "typecheck": "pnpm --filter @zhixu/core --filter @zhixu/agent-core --filter @zhixu/agent-harness --filter @zhixu/agent-os --filter @zhixu/config --filter @zhixu/skill-runtime --filter @zhixu/document-intelligence --filter @zhixu/db build && pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "db:generate": "pnpm --filter @zhixu/db db:generate",
    "db:migrate": "pnpm --filter @zhixu/db db:migrate"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "mammoth": "^1.12.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
