# ZhiXu Environment Variables

# Database
DATABASE_URL=postgresql://zhixu:zhixu@localhost:5432/zhixu

# Store type: memory (default) or prisma
STORE_TYPE=memory

# LLM Configuration (阿里云百炼 OpenAI 兼容接口)
# Get API Key: https://help.aliyun.com/zh/model-studio/get-api-key
LLM_API_KEY=
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen3.6-plus
LLM_ENABLE_THINKING=false

# Web
WEB_ORIGIN=http://localhost:3000
