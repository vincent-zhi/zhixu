{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "知序",
  "version": "0.1.0",
  "identifier": "ai.zhixu.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "知序 — AI 学习科研管家",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
